---
import { papers } from '../data/research';
import { site } from '../data/site';
---

<section id="research" class="section">
  <div class="container">
    <h2 class="section-title">Publications</h2>
    <p class="research-source">
      Auto-generated from
      <a href="https://dblp.org/pid/159/8806" target="_blank" rel="noopener noreferrer">
        DBLP
      </a>
      &middot; see also
      <a href={site.social.scholar} target="_blank" rel="noopener noreferrer">
        Google Scholar
      </a>
    </p>

    {
      papers.length === 0 ? (
        <p class="research-empty">Publication list is temporarily unavailable.</p>
      ) : (
        <ul class="research-list">
          {papers.map((paper) => (
            <li class="research-item">
              <h3 class="research-item__title">
                {paper.url ? (
                  <a href={paper.url} target="_blank" rel="noopener noreferrer">
                    {paper.title}
                  </a>
                ) : (
                  <span>{paper.title}</span>
                )}
              </h3>
              <p class="research-item__authors">
                {paper.authors.map((author, i) => (
                  <Fragment
                    >{i > 0 ? ', ' : ''}<span>{author.name}</span>{author.equal && <sup>*</sup>}</Fragment>
                ))}
              </p>
              <p class="research-item__venue">
                <span>{paper.venue}</span>
                {paper.type === 'preprint' && (
                  <span class="badge badge--preprint">preprint</span>
                )}
              </p>
              {paper.note && <p class="research-item__note">({paper.note})</p>}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>

<style>
  .research-source {
    font-size: var(--fs-sm);
    color: var(--color-fg-muted);
    margin-top: calc(-1 * var(--space-4));
    margin-bottom: var(--space-6);
  }

  .research-empty {
    color: var(--color-fg-muted);
    font-style: italic;
  }

  .research-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .research-item {
    position: relative;
  }

  .research-item__title {
    font-size: var(--fs-lg);
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: var(--space-2);
  }

  .research-item__title a {
    color: var(--color-fg);
    text-decoration: none;
  }

  .research-item__title a:hover,
  .research-item__title a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .research-item__authors {
    font-size: var(--fs-sm);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-1);
  }

  .research-item__authors sup {
    color: var(--color-accent);
    font-weight: 600;
    margin-left: 1px;
  }

  .research-item__venue {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-faint);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin: 0;
  }

  .badge {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    padding: 1px var(--space-2);
    border-radius: 999px;
    border: 1px solid var(--color-border-strong);
    color: var(--color-fg-muted);
    background: var(--color-bg-subtle);
    font-weight: 600;
    text-transform: lowercase;
  }

  .research-item__note {
    font-size: var(--fs-xs);
    color: var(--color-fg-faint);
    margin-top: var(--space-1);
    font-style: italic;
  }

  @media (max-width: 480px) {
    .research-item__title {
      font-size: var(--fs-base);
    }
  }
</style>
